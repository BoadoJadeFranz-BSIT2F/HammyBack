# Email Configuration for Password Reset
# You need to set up a Gmail App Password to use this feature
# Instructions: https://support.google.com/accounts/answer/185833

EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-here

# Supabase (database and storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# For server-side storage operations (recommended):
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Supabase storage bucket name (create this in Supabase UI):
SUPABASE_STORAGE_BUCKET=uploads

# Note: For Gmail, you need to:
# 1. Enable 2-factor authentication on your Google account
# 2. Generate an "App Password" at https://myaccount.google.com/apppasswords
# 3. Use that App Password (not your regular Gmail password) in EMAIL_PASSWORD
